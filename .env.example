# ----------------------------------------------------------------------------
# Gul Craft Stories — environment variables
#
# Copy this file to `.env.local` and fill in your real values there.
# `.env.local` is gitignored — NEVER commit real keys. The values below are
# placeholders only; replace the "..." with keys from your Stripe Dashboard.
# ----------------------------------------------------------------------------

# REQUIRED — Stripe secret key (server-side only; keep this private).
# Test mode starts with sk_test_..., live mode with sk_live_...
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_STRIPE_SECRET_KEY

# OPTIONAL — Stripe webhook signing secret (starts with whsec_...).
# Only needed if you enable the /api/stripe/webhook endpoint for automated
# order fulfilment. Get it when you create the webhook in the Stripe Dashboard.
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_SIGNING_SECRET

# OPTIONAL — your site's public URL, used to build checkout success/cancel URLs.
# In most cases this is detected automatically; set it for custom domains.
# NEXT_PUBLIC_SITE_URL=https://gulcraftstories.com

# OPTIONAL — WhatsApp number for the floating inquiry button (intl format,
# digits only, no "+"). Falls back to a placeholder until set.
# NEXT_PUBLIC_WHATSAPP_NUMBER=447700900000

# Formspree endpoints (optional). When set, the contact and bespoke forms
# send directly to the studio inbox instead of opening the visitor's email
# app. Create free forms at https://formspree.io pointing at
# gulcraftstories@gmail.com and paste each endpoint URL here.
# NEXT_PUBLIC_FORMSPREE_CONTACT=https://formspree.io/f/xxxxxxxx
# NEXT_PUBLIC_FORMSPREE_BESPOKE=https://formspree.io/f/xxxxxxxx
